{
  "name": "test-nestjs-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && find . -name node_modules -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "test-nestjs-app - Full-stack application"
}
